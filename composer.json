{
    "name": "laragear/turnstile",
    "description": "Use Cloudflare's no-CAPTCHA with HTTP/3 in your Laravel application.",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "keywords": [
        "laragear",
        "turnstile",
        "captcha",
        "cloudflare",
        "http2",
        "http3"
    ],
    "authors": [
        {
            "name": "Italo Israel Baeza Cabrera",
            "email": "darkghosthunter@gmail.com",
            "homepage": "https://github.com/sponsors/DarkGhostHunter"
        }
    ],
    "support": {
        "source": "https://github.com/Laragear/Turnstile",
        "issues": "https://github.com/Laragear/Turnstile/issues"
    },
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "illuminate/support": "12.*|13.*",
        "illuminate/http": "12.*|13.*",
        "illuminate/routing": "12.*|13.*",
        "illuminate/container": "12.*|13.*",
        "illuminate/events": "12.*|13.*",
        "illuminate/session": "12.*|13.*"
    },
    "require-dev": {
        "orchestra/testbench": "10.*|11.*"
    },
    "autoload": {
        "psr-4": {
            "Laragear\\Turnstile\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laragear\\Turnstile\\TurnstileServiceProvider"
            ],
            "aliases": {
                "Turnstile": "Laragear\\Turnstile\\Facades\\Turnstile"
            }
        }
    },
    "funding": [
        {
            "type": "Github Sponsorship",
            "url": "https://github.com/sponsors/DarkGhostHunter"
        },
        {
            "type": "Paypal",
            "url": "https://paypal.me/darkghosthunter"
        }
    ]
}
